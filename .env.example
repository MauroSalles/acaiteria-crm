# =============================================================================
# Variáveis de Ambiente — AcaiteriaCRM
# Copie para .env e configure. NÃO comite o .env no Git!
# =============================================================================

# URL do banco PostgreSQL (fornecida automaticamente pelo Render/Railway)
# DATABASE_URL=postgresql://usuario:senha@host:porta/banco

# Chave secreta para sessões Flask (OBRIGATÓRIA em produção)
# Gere uma com: python -c "import secrets; print(secrets.token_hex(32))"
# SECRET_KEY=cole-sua-chave-aqui

# Porta do servidor (definida automaticamente na nuvem)
# PORT=5000

# Ambiente (development / production)
# FLASK_ENV=production

# Connection pool PostgreSQL (opcional, valores padrão abaixo)
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20

# Chave PIX para QR Code (opcional)
# PIX_CHAVE=sua-chave-pix