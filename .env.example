# =============================================================================
# .env.example — AcaiteriaCRM (Configurações de Desenvolvimento e Produção)
# Instruções: Copie este arquivo para um novo chamado ".env" e preencha os valores.
# =============================================================================

# ---------- Configurações de Rede e Portas ----------
# Porta que será acessada no seu navegador (ex: http://seu-ip:5007)
FLASK_PORT=5007
# Porta interna onde o Gunicorn/Flask roda dentro do container (padrão: 8000)
INTERNAL_PORT=8000

# ---------- Banco de Dados PostgreSQL ----------
DB_USER=acaiteria
DB_PASSWORD=acaiteria123
DB_NAME=acaiteria_crm
DB_PORT=5432

# URL de Conexão (Utilizada pela aplicação para conectar ao banco)
# No Docker, o host do banco é o nome do serviço definido no compose ("db")
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@db:5432/${DB_NAME}

# ---------- Segurança e Ambiente ----------
# Gere uma chave com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cole-aqui-sua-chave-secreta-gerada
# Ambiente: development (testes) ou production (nuvem/nginx)
FLASK_ENV=development

# ---------- Credenciais Administrativas ----------
# Se não definidas, o sistema gera uma senha aleatória nos logs do Docker
ADMIN_EMAIL=admin@acaiteria.com
ADMIN_SENHA=sua-senha-forte-aqui

# ---------- Pagamentos e Integrações ----------
# Chave PIX para geração de QR Codes de pagamento
PIX_CHAVE=sua-chave-pix-aqui

# ---------- Ajustes de Performance (Opcional) ----------
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20